<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Base dark palette - shared across all themes -->
    <Color x:Key="BgColor">#0F1115</Color>
    <Color x:Key="PanelColor">#171A21</Color>
    <Color x:Key="Panel2Color">#1F232C</Color>
    <Color x:Key="BorderColor">#2A2F3A</Color>
    <Color x:Key="TextColor">#E6E8EE</Color>
    <Color x:Key="MutedColor">#8B93A7</Color>
    <Color x:Key="GoodColor">#3ECF8E</Color>
    <Color x:Key="WarnColor">#FFB020</Color>
    <Color x:Key="ErrColor">#FF5C5C</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
    <SolidColorBrush x:Key="Panel2Brush" Color="{StaticResource Panel2Color}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}"/>
    <SolidColorBrush x:Key="GoodBrush" Color="{StaticResource GoodColor}"/>
    <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource WarnColor}"/>
    <SolidColorBrush x:Key="ErrBrush" Color="{StaticResource ErrColor}"/>
</ResourceDictionary>
