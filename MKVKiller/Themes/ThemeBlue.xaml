<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AccentColor">#5B8CFF</Color>
    <Color x:Key="Accent2Color">#7AA2FF</Color>
    <Color x:Key="AccentGlowColor">#1F5B8CFF</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource Accent2Color}"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlowColor}"/>
</ResourceDictionary>
